<urn:uuid:2F7851A4-26EE-4bb0-813A-32F8907578A9>
        a                  mim:Attribuutsoort;
        mim:definitie      "Een eenduidig gegevensobjecttype is een gegevensobjecttype met precies één hoofdonderwerp waarvan de sleutel bekend is.\r\n\r\n!Als hoofdonderwerp = true en minimaal 1 gegevenstype sleutel = true";
        mim:kardinaliteit  "1..1";
        mim:naam           "eenduidig";
        mim:type           <urn:uuid:6D9078A3-14CB-4b1f-85A5-15207CBBBDDA> .

<urn:uuid:7762320E-5554-4b7d-AD81-A785005B91BD>
        a                  mim:Attribuutsoort;
        mim:definitie      "Een beschrijvend gegevensobjecttype is een gegevensobjecttype met precies één hoofdonderwerp, zonder dat de sleutel van het hoofdonderwerp bekend is\r\n\r\n! Als alle gegevenstype is sleutel = false dan is beschrijvend = true";
        mim:kardinaliteit  "1..1";
        mim:naam           "is beschrijvend";
        mim:type           <urn:uuid:6D9078A3-14CB-4b1f-85A5-15207CBBBDDA> .

<urn:uuid:6D9078A3-14CB-4b1f-85A5-15207CBBBDDA>
        a                            mim:PrimitiefDatatype;
        mim:definitie                "-- Definitie -- \r\nIndicatie met mogelijke waarden True, false, 1 of 0. True en 1 hebben een identieke betekenis: Ja. False en 0 hebben een identieke betekenis: Nee. Opmerking: t.a.v. Ja of Nee.";
        mim:indicatieAbstractObject  false;
        mim:naam                     "Boolean";
        mim:toelichting              "Wanneer u de Ja of Nee wilt gebruiken, gebruik dan bv. een Enumeratie genaamd Indicatie, of gebruik AN met een lengte en een (formeel) patroon." .

<urn:uuid:C10F1C3D-7DCC-4566-BB1C-D9F8A8E0C746>
        a                  mim:Attribuutsoort;
        mim:definitie      "Een strikt eenduidig gegevensobjecttype is een gegevensobjecttype over alleen eigenschappen van het hoofdonderwerp waarvan de sleutel bekend is.\r\n\r\n!Als eenduidig = true en als voor alle gegevenstype onderwerp = hoofdonderwerp.";
        mim:kardinaliteit  "1..1";
        mim:naam           "strikt eenduidig gegevensobjecttype";
        mim:type           <urn:uuid:6D9078A3-14CB-4b1f-85A5-15207CBBBDDA> .

